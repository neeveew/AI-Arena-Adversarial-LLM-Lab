<Window x:Class="AIArena.Wpf.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm"
        Icon="/Assets/ai-arena-icon.ico"
        Width="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True">
    <Border x:Name="DialogShell"
            CornerRadius="8"
            BorderThickness="2"
            PreviewMouseLeftButtonDown="DialogShell_PreviewMouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.45" BlurRadius="18" ShadowDepth="4" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="HeaderBar"
                    CornerRadius="6,6,0,0"
                    Padding="18,14">
                <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TitleText"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button x:Name="CloseButton"
                        Grid.Column="1"
                        Content="X"
                        Click="CancelButton_Click"
                        Width="32"
                        Height="28"
                        MinWidth="32"
                        MinHeight="28"
                        Padding="0"
                        Margin="12,0,0,0"
                        ToolTip="Close" />
                </Grid>
            </Border>

            <Grid x:Name="ContentPanel"
                  Grid.Row="1"
                  Margin="18"
                  MinHeight="104">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border x:Name="ToneBadge"
                        Width="34"
                        Height="34"
                        CornerRadius="17"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top">
                    <TextBlock x:Name="ToneText"
                               Text="!"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <TextBlock x:Name="MessageText"
                           Grid.Column="1"
                           FontSize="15"
                           LineHeight="22"
                           TextWrapping="Wrap" />
            </Grid>

            <UniformGrid Grid.Row="2"
                         Columns="2"
                         HorizontalAlignment="Right"
                         Width="280"
                         Margin="18,0,18,18">
                <Button x:Name="CancelButton"
                        Content="Cancel"
                        Click="CancelButton_Click"
                        Margin="0,0,8,0" />
                <Button x:Name="ConfirmButton"
                        Content="Confirm"
                        Click="ConfirmButton_Click"
                        Margin="8,0,0,0" />
            </UniformGrid>
        </Grid>
    </Border>
</Window>
