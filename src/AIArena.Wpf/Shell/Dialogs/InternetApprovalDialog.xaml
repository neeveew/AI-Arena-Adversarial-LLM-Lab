<Window x:Class="AIArena.Wpf.InternetApprovalDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Internet Approval"
        Icon="/Assets/ai-arena-icon.ico"
        Width="620"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True">
    <Border x:Name="DialogShell"
            CornerRadius="8"
            BorderThickness="2"
            PreviewMouseLeftButtonDown="DialogShell_PreviewMouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.45" BlurRadius="18" ShadowDepth="4" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="HeaderBar"
                    CornerRadius="6,6,0,0"
                    Padding="18,14">
                <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TitleText"
                           Text="Approve Internet Request"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button x:Name="CloseButton"
                        Grid.Column="1"
                        Content="X"
                        Click="DenyButton_Click"
                        Width="32"
                        Height="28"
                        MinWidth="32"
                        MinHeight="28"
                        Padding="0"
                        Margin="12,0,0,0"
                        ToolTip="Deny" />
                </Grid>
            </Border>

            <Border x:Name="RequestPanel"
                    Grid.Row="1"
                    Margin="18"
                    Padding="14"
                    BorderThickness="1"
                    CornerRadius="6">
                <TextBlock x:Name="RequestText"
                           FontSize="15"
                           LineHeight="22"
                           TextWrapping="Wrap" />
            </Border>

            <UniformGrid Grid.Row="2"
                         Columns="3"
                         HorizontalAlignment="Right"
                         Width="520"
                         Margin="18,0,18,18">
                <Button x:Name="DenyButton"
                        Content="Deny"
                        Click="DenyButton_Click"
                        Margin="0,0,8,0" />
                <Button x:Name="AlwaysApproveButton"
                        Content="Always Approve"
                        Click="AlwaysApproveButton_Click"
                        Margin="8,0,8,0" />
                <Button x:Name="ApproveOnceButton"
                        Content="Approve Once"
                        Click="ApproveOnceButton_Click"
                        Margin="8,0,0,0" />
            </UniformGrid>
        </Grid>
    </Border>
</Window>
