                                BorderBrush="{DynamicResource PrimaryBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="8">
                            <Grid Width="320">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="34" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="38" />
