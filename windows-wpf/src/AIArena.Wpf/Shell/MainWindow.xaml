                                        <TextBlock Text="Context" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" HorizontalAlignment="Right" />
                                        <TextBlock x:Name="SessionOverviewContextText" Text="-" Foreground="{DynamicResource TextBrush}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="2"
