                                        <TextBlock Text="Tokens" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" HorizontalAlignment="Right" />
                                        <TextBlock x:Name="SessionOverviewTokensText" Text="-" Foreground="{DynamicResource TextBrush}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="2"
                                        Style="{StaticResource SessionOverviewHotspot}"
