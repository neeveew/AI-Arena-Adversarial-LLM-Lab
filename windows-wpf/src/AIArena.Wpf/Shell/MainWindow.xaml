                        </Border>
                    </Popup>
                    </Grid>
                    <Button x:Name="ExportTranscriptBottomButton"
                            Click="ExportTranscriptButton_Click"
                            Width="30"
                            Height="30"
                            MinHeight="30"
                            Padding="0"
                            Background="Transparent"
                            BorderBrush="{DynamicResource DisabledBorderBrush}"
                            Foreground="{DynamicResource MutedTextBrush}"
                            ToolTip="Export transcript">
                        <TextBlock Text="&#xE8E5;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                    <Grid VerticalAlignment="Center" Margin="10,0,14,0">
