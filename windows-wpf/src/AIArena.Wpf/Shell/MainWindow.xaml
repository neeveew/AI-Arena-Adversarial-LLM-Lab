                                        <TextBlock Text="Agents" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" />
                                        <TextBlock x:Name="SessionOverviewParticipantsText" Text="-" Foreground="{DynamicResource TextBrush}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1"
                                        Grid.Column="1"
                                        Style="{StaticResource SessionOverviewHotspot}"
                                        Margin="-4,-3,-4,3"
                                        MouseLeftButtonUp="SessionOverviewPerformance_MouseLeftButtonUp"
