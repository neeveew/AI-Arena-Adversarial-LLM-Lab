                                <UniformGrid Columns="2" Margin="0,0,0,8">
                                    <Border Background="{DynamicResource InputBrush}" BorderBrush="{DynamicResource DisabledBorderBrush}" BorderThickness="1" Padding="8,6" Margin="0,0,5,5">
                                        <StackPanel>
                                            <TextBlock Text="Base URL" Foreground="{DynamicResource MutedTextBrush}" FontSize="10" />
                                            <TextBlock x:Name="ProviderHealthBaseUrlText" Text="-" Foreground="{DynamicResource TextBrush}" FontSize="11" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{DynamicResource InputBrush}" BorderBrush="{DynamicResource DisabledBorderBrush}" BorderThickness="1" Padding="8,6" Margin="0,0,0,5">
                                        <StackPanel>
                                            <TextBlock Text="Models" Foreground="{DynamicResource MutedTextBrush}" FontSize="10" />
                                            <TextBlock x:Name="ProviderHealthModelCountText" Text="-" Foreground="{DynamicResource TextBrush}" FontSize="11" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{DynamicResource InputBrush}" BorderBrush="{DynamicResource DisabledBorderBrush}" BorderThickness="1" Padding="8,6" Margin="0,0,5,0">
