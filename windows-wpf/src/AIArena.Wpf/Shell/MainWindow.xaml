                           AllowsTransparency="True">
                        <Border Background="{DynamicResource TopBarBrush}"
                                BorderBrush="{DynamicResource PrimaryBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12"
