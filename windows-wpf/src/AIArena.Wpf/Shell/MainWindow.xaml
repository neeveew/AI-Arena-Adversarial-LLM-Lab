                                        MouseMove="TranscriptSearchDragHandle_MouseMove"
                                        MouseLeftButtonUp="TranscriptSearchDragHandle_MouseLeftButtonUp">
                                    <Border Width="34"
                                            Height="2"
                                            CornerRadius="1"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
