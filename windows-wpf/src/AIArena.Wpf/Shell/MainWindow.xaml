                                <ComboBoxItem Content="Manual" Tag="manual" IsSelected="True" />
                                <ComboBoxItem Content="Hostile review" Tag="hostile_review" />
                                <ComboBoxItem Content="Evidence trial" Tag="evidence_trial" />
                                <ComboBoxItem Content="Consensus trap" Tag="consensus_trap" />
                                <ComboBoxItem Content="Chaos room" Tag="chaos_room" />
