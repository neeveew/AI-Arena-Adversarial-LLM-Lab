                                        <TextBlock Text="Existing session" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                                        <ComboBox x:Name="SessionPicker"
                                                  SelectionChanged="SessionPicker_SelectionChanged"
                                                  Margin="0,0,0,8" />
                                        <TextBlock Text="New session name" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                                        <TextBox x:Name="NewSessionText" Margin="0,0,0,8" />
                                        <WrapPanel Margin="0,0,0,8">
                                            <Button x:Name="CreateSessionButton" Content="CREATE / SWITCH" Click="CreateSessionButton_Click" Margin="0,0,8,8" />
                                            <Button x:Name="DeleteSessionButton"
                                                    Content="DELETE SESSION"
                                                    Click="DeleteSessionButton_Click"
                                                    Background="{DynamicResource DangerBrush}"
                                                    BorderBrush="{DynamicResource DangerBorderBrush}"
                                                    Foreground="{DynamicResource DangerTextBrush}"
                                                    Margin="0,0,0,8" />
                                        </WrapPanel>
                                    </StackPanel>
                                    <TextBlock x:Name="LoadStatus"
                                               Grid.Row="2"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,0" />
                                </Grid>
                            </Border>
                        </Grid>
                        <TextBlock Text="SCENARIO TEMPLATES" Style="{StaticResource SectionTitle}" Margin="0,0,0,10" />
                        <Border Background="{DynamicResource CardBrush}"
                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Save current match framing, cast, locks, participants, and model assignments."
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="Template name" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                                    <TextBox x:Name="ScenarioTemplateNameText"
                                             Background="{DynamicResource InputBrush}"
                                             Foreground="White"
                                             BorderBrush="{DynamicResource ControlBorderBrush}"
                                             Padding="8"
                                             Margin="0,0,0,8" />
                                    <Button x:Name="SaveScenarioTemplateButton"
                                            Content="SAVE TEMPLATE"
                                            Click="SaveScenarioTemplateButton_Click"
                                            Background="{DynamicResource PrimaryBrush}"
                                            BorderBrush="{DynamicResource PrimaryBorderBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Saved template" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                                    <ComboBox x:Name="ScenarioTemplatePicker"
                                              DisplayMemberPath="Name"
                                              Background="{DynamicResource InputBrush}"
                                              Foreground="White"
                                              BorderBrush="{DynamicResource ControlBorderBrush}"
                                              Padding="8"
                                              Margin="0,0,0,8" />
                                    <WrapPanel Margin="0,0,0,8">
                                        <Button x:Name="ApplyScenarioTemplateButton"
                                                Content="APPLY TEMPLATE"
                                                Click="ApplyScenarioTemplateButton_Click"
                                                Margin="0,0,8,8" />
                                        <Button x:Name="DeleteScenarioTemplateButton"
                                                Content="DELETE"
                                                Click="DeleteScenarioTemplateButton_Click"
                                                Background="{DynamicResource DangerBrush}"
                                                BorderBrush="{DynamicResource DangerBorderBrush}"
                                                Foreground="{DynamicResource DangerTextBrush}"
                                                Margin="0,0,0,8" />
                                    </WrapPanel>
                                    <TextBlock x:Name="ScenarioTemplateStatus"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="No template selected." />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid x:Name="NewsPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="News" Foreground="White" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock x:Name="NewsSummaryText"
                               Text="Fetched sources and model-requested internet activity"
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="NewsItems" />
                </ScrollViewer>
            </Grid>
        </Grid>

        <ScrollViewer x:Name="RightRailScrollViewer"
                      Grid.Row="1"
                      Grid.Column="2"
                      Margin="0,14,14,14"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Style="{StaticResource Card}" Opacity="1" Padding="8">
                    <StackPanel>
                        <TextBlock Text="Arena Controls" Style="{StaticResource SectionTitle}" Margin="0,0,0,6" />
                        <UniformGrid Columns="3" Rows="2">
                            <Button x:Name="AutoChatButton" Content="AUTO CHAT" Click="AutoChatButton_Click" Background="{DynamicResource PrimaryBrush}" BorderBrush="{DynamicResource PrimaryBorderBrush}" FontSize="10.5" Padding="5,4" Margin="0,0,5,5" MinWidth="0" MinHeight="30" />
                            <Button x:Name="OneTurnButton" Content="1 TURN" Click="OneTurnButton_Click" Background="{DynamicResource PrimaryBrush}" BorderBrush="{DynamicResource PrimaryBorderBrush}" FontSize="10.5" Padding="5,4" Margin="0,0,5,5" MinWidth="0" MinHeight="30" />
                            <Button x:Name="NarrateNowButton" Content="NARRATE" Click="NarrateNowButton_Click" Background="{DynamicResource AssistBrush}" BorderBrush="{DynamicResource AssistBorderBrush}" FontSize="10.5" Padding="5,4" Margin="0,0,0,5" MinWidth="0" MinHeight="30" />
                            <Button x:Name="StopButton" Content="PAUSE" Click="StopButton_Click" Background="{DynamicResource InputBrush}" BorderBrush="{DynamicResource BetaAccentBrush}" Foreground="{DynamicResource BetaAccentBrush}" FontSize="10.5" Padding="5,4" Margin="0,0,5,0" MinWidth="0" MinHeight="30" IsEnabled="False" />
                            <Button x:Name="ResetButton" Content="RESET" Click="ResetButton_Click" Background="{DynamicResource InputBrush}" BorderBrush="{DynamicResource DangerBorderBrush}" Foreground="{DynamicResource DangerTextBrush}" FontSize="10.5" Padding="5,4" Margin="0,0,5,0" MinWidth="0" MinHeight="30" />
                            <Button x:Name="CurateNewsButton" Content="NEWS" Click="CurateNewsButton_Click" Background="{DynamicResource AssistBrush}" BorderBrush="{DynamicResource AssistBorderBrush}" FontSize="10.5" Padding="5,4" MinWidth="0" MinHeight="30" />
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border x:Name="AgentPerformanceCard" Style="{StaticResource QuietCard}" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Agent Performance" Style="{StaticResource SectionTitle}" Margin="0,0,0,6" />
                        <StackPanel x:Name="AgentPerformanceItems" />
                    </StackPanel>
                </Border>
                <Popup x:Name="AgentPerformanceDetailPopup"
                       Placement="Left"
                       HorizontalOffset="-8"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                    <Border Width="360"
                            MaxHeight="500"
                            Background="{DynamicResource TopBarBrush}"
                            BorderBrush="{DynamicResource PrimaryBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="7"
                            Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="34" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Performance Detail"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           VerticalAlignment="Center" />
                                <Button x:Name="AgentPerformanceDetailCloseButton"
                                        Grid.Column="1"
                                        Content="X"
                                        Click="AgentPerformanceDetailCloseButton_Click"
                                        MinWidth="30"
                                        MinHeight="28"
                                        Padding="0"
                                        ToolTip="Close performance detail" />
                            </Grid>
                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="AgentPerformanceDetailContent" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Popup>

                <Border Style="{StaticResource Card}" Opacity="1">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Operator Turn" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                            <TextBlock x:Name="OperatorTurnMeterText"
                                       Grid.Column="1"
                                       Text="0 chars / ~0 tok"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <UniformGrid Columns="3" Margin="0,0,0,8">
                            <Button x:Name="OperatorPublicRouteButton"
                                    Content="PUBLIC"
                                    Click="OperatorPublicRouteButton_Click"
                                    FontSize="10.5"
                                    Padding="5,4"
                                    Margin="0,0,5,0"
                                    MinHeight="28"
                                    ToolTip="Add a public operator turn to the transcript." />
                            <Button x:Name="OperatorPrivateRouteButton"
                                    Content="PRIVATE"
                                    Click="OperatorPrivateRouteButton_Click"
                                    FontSize="10.5"
                                    Padding="5,4"
                                    Margin="0,0,5,0"
                                    MinHeight="28"
                                    ToolTip="Write private guidance into agent memory notes." />
                            <Button x:Name="OperatorNarratorRouteButton"
                                    Content="NARRATOR"
                                    Click="OperatorNarratorRouteButton_Click"
                                    FontSize="10.5"
                                    Padding="5,4"
                                    MinHeight="28"
                                    ToolTip="Ask the narrator to reply publicly." />
                        </UniformGrid>
                        <Grid x:Name="OperatorPrivateTargetRow" Visibility="Collapsed" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Target"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <ComboBox x:Name="OperatorPrivateTargetPicker"
                                      Grid.Column="1"
                                      Height="30"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="All active agents" Tag="all" IsSelected="True" />
                                <ComboBoxItem Content="Alpha" Tag="alpha" />
                                <ComboBoxItem Content="Beta" Tag="beta" />
                                <ComboBoxItem Content="Gamma" Tag="gamma" />
                                <ComboBoxItem Content="Delta" Tag="delta" />
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="OperatorTemplatePicker"
                                      Height="30"
                                      IsEditable="True"
                                      ToolTip="Reusable operator templates" />
                            <Button Grid.Column="1"
                                    Content="USE"
                                    Click="UseOperatorTemplateButton_Click"
                                    FontSize="10.5"
                                    Padding="8,4"
                                    MinHeight="30"
                                    Margin="6,0,0,0" />
                            <Button Grid.Column="2"
                                    Content="SAVE"
                                    Click="SaveOperatorTemplateButton_Click"
                                    FontSize="10.5"
                                    Padding="8,4"
                                    MinHeight="30"
                                    Margin="6,0,0,0"
                                    ToolTip="Save current operator text as a template" />
                        </Grid>
                        <Grid>
                            <TextBox x:Name="OperatorTurnText"
                                     MinHeight="78"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalContentAlignment="Top"
                                     HorizontalContentAlignment="Left"
                                     Padding="8,6"
                                     Text=""
                                     Tag="Inject public operator turn..."
                                     TextChanged="OperatorTurnText_TextChanged" />
                        </Grid>
                        <Button x:Name="SendTurnButton"
                                Content="SEND TURN"
                                Click="SendTurnButton_Click"
                                Background="{DynamicResource DangerBrush}"
                                BorderBrush="{DynamicResource OperatorAccentBrush}"
                                Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border x:Name="AppSettingsPanel"
                Grid.RowSpan="2"
                Grid.ColumnSpan="3"
                Width="520"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Margin="0"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource ControlBorderBrush}"
                BorderThickness="1,0,0,0"
                CornerRadius="0"
                Padding="18"
                Panel.ZIndex="20"
                Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.45" BlurRadius="18" ShadowDepth="4" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Settings" Foreground="White" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Text="Provider, models, internet, and app behavior" Foreground="{DynamicResource MutedTextBrush}" />
                        <Border Background="{DynamicResource InputBrush}"
                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,8"
                                Margin="0,12,0,0">
                            <TextBlock x:Name="SettingsProviderStatusText"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Text="Provider status unavailable." />
                        </Border>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="X"
                            Click="CloseAppSettingsButton_Click"
                            Width="38"
                            MinWidth="38"
                            Height="38"
                            Padding="0" />
                </Grid>
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                <Expander x:Name="ModelProviderSettingsExpander" Header="Model Provider" Style="{StaticResource SettingsExpander}" IsExpanded="True">
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="Provider base URL" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBox x:Name="ProviderBaseUrlText"
                                  Background="{DynamicResource InputBrush}"
                                  Foreground="White"
                                  BorderBrush="{DynamicResource ControlBorderBrush}"
                                  Padding="8"
                                  Margin="0,0,0,8"
                                  LostKeyboardFocus="ProviderBaseUrlText_Commit"
                                  KeyDown="ProviderBaseUrlText_KeyDown" />
                        <TextBlock Text="Default model" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="116" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="ProviderModelText"
                                      Grid.Column="0"
                                      IsEditable="True"
                                      IsTextSearchEnabled="False"
                                      SelectionChanged="ProviderModelText_SelectionChanged"
                                      LostKeyboardFocus="ProviderModelText_Commit"
                                      KeyDown="ProviderModelText_KeyDown"
                                      Background="{DynamicResource InputBrush}"
                                      Foreground="White"
                                      BorderBrush="{DynamicResource ControlBorderBrush}"
                                      Padding="8"
                                      ToolTip="Pick an advertised provider model or type one manually." />
                            <TextBlock x:Name="DefaultModelStatusText"
                                       Grid.Column="2"
                                       Text="not selected"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextAlignment="Right"
                                       TextWrapping="Wrap" />
                        </Grid>

                        <TextBlock Text="Participant models" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,2,0,6" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="116" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Alpha" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <ComboBox x:Name="AlphaRoleModelText"
                                      Grid.Row="0"
                                      Grid.Column="2"
                                      Tag="alpha"
                                      IsEditable="True"
                                      IsTextSearchEnabled="False"
                                      SelectionChanged="ParticipantModelText_SelectionChanged"
                                      LostKeyboardFocus="ParticipantModelText_Commit"
                                      KeyDown="ParticipantModelText_KeyDown"
                                      Background="{DynamicResource InputBrush}"
                                      Foreground="White"
                                      BorderBrush="{DynamicResource ControlBorderBrush}"
                                      Padding="8"
                                      ToolTip="Pick an advertised provider model, type one manually, or leave blank to use default." />
                            <TextBlock x:Name="AlphaModelStatusText" Grid.Row="0" Grid.Column="4" Text="inherits default" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" TextAlignment="Right" TextWrapping="Wrap" />
                            <TextBlock Grid.Row="2" Text="Beta" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <ComboBox x:Name="BetaRoleModelText"
                                      Grid.Row="2"
                                      Grid.Column="2"
                                      Tag="beta"
                                      IsEditable="True"
                                      IsTextSearchEnabled="False"
                                      SelectionChanged="ParticipantModelText_SelectionChanged"
                                      LostKeyboardFocus="ParticipantModelText_Commit"
                                      KeyDown="ParticipantModelText_KeyDown"
                                      Background="{DynamicResource InputBrush}"
                                      Foreground="White"
                                      BorderBrush="{DynamicResource ControlBorderBrush}"
                                      Padding="8"
                                      ToolTip="Pick an advertised provider model, type one manually, or leave blank to use default." />
                            <TextBlock x:Name="BetaModelStatusText" Grid.Row="2" Grid.Column="4" Text="inherits default" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" TextAlignment="Right" TextWrapping="Wrap" />
                            <TextBlock Grid.Row="4" Text="Gamma" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <ComboBox x:Name="GammaRoleModelText"
                                      Grid.Row="4"
                                      Grid.Column="2"
                                      Tag="gamma"
                                      IsEditable="True"
                                      IsTextSearchEnabled="False"
                                      SelectionChanged="ParticipantModelText_SelectionChanged"
                                      LostKeyboardFocus="ParticipantModelText_Commit"
                                      KeyDown="ParticipantModelText_KeyDown"
                                      Background="{DynamicResource InputBrush}"
                                      Foreground="White"
                                      BorderBrush="{DynamicResource ControlBorderBrush}"
                                      Padding="8"
                                      ToolTip="Pick an advertised provider model, type one manually, or leave blank to use default." />
                            <TextBlock x:Name="GammaModelStatusText" Grid.Row="4" Grid.Column="4" Text="inherits default" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" TextAlignment="Right" TextWrapping="Wrap" />
                            <TextBlock Grid.Row="6" Text="Delta" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <ComboBox x:Name="DeltaRoleModelText"
                                      Grid.Row="6"
                                      Grid.Column="2"
                                      Tag="delta"
                                      IsEditable="True"
                                      IsTextSearchEnabled="False"
                                      SelectionChanged="ParticipantModelText_SelectionChanged"
                                      LostKeyboardFocus="ParticipantModelText_Commit"
                                      KeyDown="ParticipantModelText_KeyDown"
                                      Background="{DynamicResource InputBrush}"
                                      Foreground="White"
                                      BorderBrush="{DynamicResource ControlBorderBrush}"
                                      Padding="8"
                                      ToolTip="Pick an advertised provider model, type one manually, or leave blank to use default." />
                            <TextBlock x:Name="DeltaModelStatusText" Grid.Row="6" Grid.Column="4" Text="inherits default" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" TextAlignment="Right" TextWrapping="Wrap" />
                            <TextBlock Grid.Row="8" Text="Narrator" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <ComboBox x:Name="NarratorRoleModelText"
                                      Grid.Row="8"
                                      Grid.Column="2"
                                      Tag="narrator"
                                      IsEditable="True"
                                      IsTextSearchEnabled="False"
                                      SelectionChanged="ParticipantModelText_SelectionChanged"
                                      LostKeyboardFocus="ParticipantModelText_Commit"
                                      KeyDown="ParticipantModelText_KeyDown"
                                      Background="{DynamicResource InputBrush}"
                                      Foreground="White"
                                      BorderBrush="{DynamicResource ControlBorderBrush}"
                                      Padding="8"
                                      ToolTip="Pick an advertised provider model, type one manually, or leave blank to use default." />
                            <TextBlock x:Name="NarratorModelStatusText" Grid.Row="8" Grid.Column="4" Text="inherits default" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" TextAlignment="Right" TextWrapping="Wrap" />
                        </Grid>
                        <TextBlock Text="Model summary" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBlock x:Name="RoleModelSummaryText"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                        <Button x:Name="PreloadSelectedModelsButton"
                                Content="PRELOAD SELECTED MODELS"
                                Click="PreloadSelectedModelsButton_Click"
                                Margin="0,0,0,8"
                                ToolTip="Ask LM Studio to load the default model plus any participant-specific overrides." />
                        <TextBlock x:Name="PreloadModelsStatusText"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8"
                                   Text="Preload telemetry appears here." />
                        <WrapPanel x:Name="PreloadModelsItems"
                                   Margin="0,0,0,8" />

                        <TextBlock Text="Active participants" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,2,0,6" />
                        <ComboBox x:Name="ActiveParticipantsPicker"
                                  Background="{DynamicResource InputBrush}"
                                  Foreground="White"
                                  BorderBrush="{DynamicResource ControlBorderBrush}"
                                  Padding="8"
                                  Margin="0,0,0,8">
                            <ComboBoxItem Content="1 active agent" Tag="1" />
                            <ComboBoxItem Content="2 active agents" Tag="2" />
                            <ComboBoxItem Content="3 active agents" Tag="3" />
                            <ComboBoxItem Content="4 active agents" Tag="4" />
                        </ComboBox>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Timeout" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <TextBox x:Name="ProviderTimeoutText"
                                         Background="{DynamicResource InputBrush}"
                                         Foreground="White"
                                         BorderBrush="{DynamicResource ControlBorderBrush}"
                                         Padding="8" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Temperature" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <TextBox x:Name="ProviderTemperatureText"
                                         Background="{DynamicResource InputBrush}"
                                         Foreground="White"
                                         BorderBrush="{DynamicResource ControlBorderBrush}"
                                         Padding="8" />
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Max output" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <TextBox x:Name="ProviderMaxOutputText"
                                         Background="{DynamicResource InputBrush}"
                                         Foreground="White"
                                         BorderBrush="{DynamicResource ControlBorderBrush}"
                                         Padding="8" />
                            </StackPanel>
                        </Grid>
                        <Button x:Name="TestProviderButton"
                                Content="TEST PROVIDER"
                                Click="TestProviderButton_Click"
                                Margin="0,4,0,0" />
                        <TextBlock x:Name="ProviderTestStatus"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0" />
                        <TextBlock x:Name="ProviderModelsStatus"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"
                                   Text="Model list refreshes while settings are open." />
                    </StackPanel>
                </Expander>

                <Expander Header="Auto Chat" Style="{StaticResource SettingsExpander}" IsExpanded="False">
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="Auto Chat cadence" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <ComboBox x:Name="AutoChatCadencePicker"
                                  Background="{DynamicResource InputBrush}"
                                  Foreground="White"
                                  BorderBrush="{DynamicResource ControlBorderBrush}"
                                  Padding="8"
                                  Margin="0,0,0,4">
                            <ComboBoxItem Content="0.5s" Tag="0.5" />
                            <ComboBoxItem Content="1.2s" Tag="1.2" IsSelected="True" />
                            <ComboBoxItem Content="3s" Tag="3" />
                            <ComboBoxItem Content="5s" Tag="5" />
                        </ComboBox>
                    </StackPanel>
                </Expander>

                <Expander Header="Visuals" Style="{StaticResource SettingsExpander}" IsExpanded="False">
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="Transcript avatars" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <ComboBox x:Name="AvatarStylePicker"
                                  SelectionChanged="VisualSettings_Changed"
                                  Background="{DynamicResource InputBrush}"
                                  Foreground="White"
                                  BorderBrush="{DynamicResource ControlBorderBrush}"
                                  Padding="8"
                                  Margin="0,0,0,8"
                                  ToolTip="Select one deterministic avatar style for transcript speakers.">
                            <ComboBoxItem Content="Champion portrait pack" Tag="pack" />
                            <ComboBoxItem Content="Procedural robot portraits" Tag="procedural" />
                            <ComboBoxItem Content="Simple robot icons" Tag="simple" />
                            <ComboBoxItem Content="Initials" Tag="initials" />
                        </ComboBox>
                        <TextBlock Text="Stronger robot identities make agents easier to recognize at a glance."
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10" />
                        <TextBlock Text="System event avatar" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <ComboBox x:Name="SystemGlyphStylePicker"
                                  SelectionChanged="VisualSettings_Changed"
                                  Background="{DynamicResource InputBrush}"
                                  Foreground="White"
                                  BorderBrush="{DynamicResource ControlBorderBrush}"
                                  Padding="8"
                                  Margin="0,0,0,8"
                                  ToolTip="Select one rendering style for system, internet, and error events.">
                            <ComboBoxItem Content="Warning / server glyph" Tag="glyph" />
                            <ComboBoxItem Content="Fallback initial" Tag="fallback" />
                        </ComboBox>
                        <TextBlock Text="Top transcript strip" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <ComboBox x:Name="TopStripModePicker"
                                  SelectionChanged="VisualSettings_Changed"
                                  Background="{DynamicResource InputBrush}"
                                  Foreground="White"
                                  BorderBrush="{DynamicResource ControlBorderBrush}"
                                  Padding="8"
                                  ToolTip="Choose what appears above the transcript cards.">
                            <ComboBoxItem Content="Discourse diagnostics" Tag="diagnostics" />
                            <ComboBoxItem Content="System telemetry" Tag="telemetry" />
                            <ComboBoxItem Content="Hidden" Tag="hidden" />
                        </ComboBox>
                    </StackPanel>
                </Expander>

                <Expander Header="News / Internet" Style="{StaticResource SettingsExpander}" IsExpanded="False">
                    <StackPanel Margin="0,8,0,0">
                        <CheckBox x:Name="UseInternetCheckBox"
                                  Content="Use internet"
                                  Style="{StaticResource ToggleSwitchCheckBox}"
                                  Foreground="{DynamicResource TextBrush}"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,10" />
                        <TextBlock Text="Mode" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <ComboBox x:Name="InternetModePicker"
                                  Background="{DynamicResource InputBrush}"
                                  Foreground="White"
                                  BorderBrush="{DynamicResource ControlBorderBrush}"
                                  Margin="0,0,0,10">
                            <ComboBoxItem Content="Off" Tag="off" />
                            <ComboBoxItem Content="Manual" Tag="manual" />
                            <ComboBoxItem Content="Model requested" Tag="model_requested" />
                            <ComboBoxItem Content="Auto" Tag="auto" />
                        </ComboBox>
                        <TextBlock Text="Off blocks all fetches. Manual allows user buttons. Model Requested allows approved model tool calls. Auto allows manual, model-requested, and scheduled drops."
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10" />
                        <TextBlock Text="Internet source scope" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <ComboBox x:Name="InternetSourceScopePicker"
                                  Background="{DynamicResource InputBrush}"
                                  Foreground="White"
                                  BorderBrush="{DynamicResource ControlBorderBrush}"
                                  Margin="0,0,0,10">
                            <ComboBoxItem Content="Trusted sources only" Tag="trusted" />
                            <ComboBoxItem Content="Open web allowed" Tag="open_web" />
                        </ComboBox>
                        <TextBlock Text="Trusted sources limits direct URL fetches to configured source domains. Open web allows arbitrary URLs, still gated by permissions and approval."
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10" />
                        <TextBlock Text="Max results" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBox x:Name="InternetMaxResultsText"
                                 Background="{DynamicResource InputBrush}"
                                 Foreground="White"
                                 BorderBrush="{DynamicResource ControlBorderBrush}"
                                 Padding="8"
                                 Margin="0,0,0,10" />
                        <TextBlock Text="Requester permissions" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="1.25*" />
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="AllowParticipantInternetCheckBox"
                                      Content="Participants"
                                      Style="{StaticResource ToggleSwitchCheckBox}"
                                      Foreground="{DynamicResource TextBrush}"
                                      MinWidth="0" />
                            <CheckBox x:Name="AllowNarratorInternetCheckBox"
                                      Grid.Column="2"
                                      Content="Narrator"
                                      Style="{StaticResource ToggleSwitchCheckBox}"
                                      Foreground="{DynamicResource TextBrush}"
                                      MinWidth="0" />
                            <CheckBox x:Name="RequireInternetApprovalCheckBox"
                                      Grid.Column="4"
                                      Content="Require approval"
                                      Style="{StaticResource ToggleSwitchCheckBox}"
                                      Foreground="{DynamicResource TextBrush}"
                                      MinWidth="0" />
                        </Grid>
                    </StackPanel>
                </Expander>

                <Expander Header="Context Windows" Style="{StaticResource SettingsExpander}" IsExpanded="False">
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="Controls how much recent arena state is sent to model calls."
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10" />
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Transcript turns" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <TextBox x:Name="ContextTranscriptWindowText"
                                         Background="{DynamicResource InputBrush}"
                                         Foreground="White"
                                         BorderBrush="{DynamicResource ControlBorderBrush}"
                                         Padding="8"
                                         ToolTip="Recent public transcript messages available to agents and narrator." />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Private notes" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <TextBox x:Name="ContextPrivateWindowText"
                                         Background="{DynamicResource InputBrush}"
                                         Foreground="White"
                                         BorderBrush="{DynamicResource ControlBorderBrush}"
                                         Padding="8"
                                         ToolTip="Recent private notes retained per agent." />
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Pinned notes" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <TextBox x:Name="ContextNotesWindowText"
                                         Background="{DynamicResource InputBrush}"
                                         Foreground="White"
                                         BorderBrush="{DynamicResource ControlBorderBrush}"
                                         Padding="8"
                                         ToolTip="Pinned or saved note window used by context builders." />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Current summary" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBox x:Name="ContextSummaryText"
                                 Background="{DynamicResource InputBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource DisabledBorderBrush}"
                                 Padding="8"
                                 MinHeight="80"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                </Expander>

                <Expander Header="Help / About" Style="{StaticResource SettingsExpander}" IsExpanded="False">
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="AI Arena"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="AboutVersionText"
                                   Text="Version loading..."
                                   Foreground="{DynamicResource PrimaryBorderBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,2,0,10" />
                        <TextBlock Foreground="{DynamicResource TextBrush}"
                                   TextWrapping="Wrap"
                                   Text="Native Windows adversarial multi-agent LLM lab for running, steering, observing, and diagnosing conversations between local or OpenAI-compatible language models.&#x0a;&#x0a;Author: Dominik Fiala&#x0a;Code: Codex 5.5&#x0a;&#x0a;Licence: Shareable No-Derivatives Software Licence 1.0&#x0a;Copyright © 2026 Dominik Fiala&#x0a;&#x0a;You may share AI Arena in its original, unmodified form. Modified redistribution requires written permission from the author." />
                        <Button x:Name="OpenReleasesButton"
                                Content="OPEN GITHUB RELEASES"
                                Click="OpenReleasesButton_Click"
                                Margin="0,12,0,0"
                                ToolTip="Open the AI Arena GitHub releases page" />
                    </StackPanel>
                </Expander>
                    </StackPanel>
                </ScrollViewer>
                <Border Grid.Row="2"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="0,14,0,0"
                        Margin="0,14,0,0">
                    <Button x:Name="ApplySettingsButton"
                            Content="APPLY SETTINGS"
                            Click="ApplySettingsButton_Click"
                            Background="{DynamicResource PrimaryBrush}"
                            BorderBrush="{DynamicResource PrimaryBorderBrush}"
                            Margin="0" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
