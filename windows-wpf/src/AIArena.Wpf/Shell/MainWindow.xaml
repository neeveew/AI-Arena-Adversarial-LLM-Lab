                        <TextBlock Grid.Column="8" Text="|" Foreground="{DynamicResource ControlBorderBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="9" Text="Turns:" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" />
                        <TextBlock x:Name="TopTurnsValue" Grid.Column="10" Text="0" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="4,0,0,0" />
                    </Grid>
                    <Popup x:Name="ProviderHealthPopup"
                           PlacementTarget="{Binding ElementName=TopProviderValue}"
