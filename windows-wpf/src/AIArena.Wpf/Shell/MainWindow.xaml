                                        <TextBlock Text="Turns" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" HorizontalAlignment="Right" />
                                        <TextBlock x:Name="SessionOverviewTurnsText" Text="0" Foreground="{DynamicResource TextBrush}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1"
