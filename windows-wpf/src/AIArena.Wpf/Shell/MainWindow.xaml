                        <TextBlock Grid.Column="5" Text="|" Foreground="{DynamicResource ControlBorderBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="6" Text="Current turn:" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" />
