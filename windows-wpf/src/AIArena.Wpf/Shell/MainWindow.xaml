                                            <TextBlock x:Name="ProviderHealthDefaultModelText" Text="-" Foreground="{DynamicResource TextBrush}" FontSize="11" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{DynamicResource InputBrush}" BorderBrush="{DynamicResource DisabledBorderBrush}" BorderThickness="1" Padding="8,6">
                                        <StackPanel>
                                            <TextBlock Text="Last check" Foreground="{DynamicResource MutedTextBrush}" FontSize="10" />
