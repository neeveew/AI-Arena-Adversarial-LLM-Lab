<Window x:Class="AIArena.Wpf.TextEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit"
        Icon="/Assets/ai-arena-icon.ico"
        Width="680"
        Height="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True">
    <Border x:Name="DialogShell"
            CornerRadius="8"
            BorderThickness="2"
            PreviewMouseLeftButtonDown="DialogShell_PreviewMouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.45" BlurRadius="18" ShadowDepth="4" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="HeaderBar"
                    CornerRadius="6,6,0,0"
                    Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="TitleText"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="SubtitleText"
                                   Text="Changes apply immediately and lock this item."
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                    <Button x:Name="CloseButton"
                            Grid.Column="1"
                            Content="X"
                            Click="CancelButton_Click"
                            Width="32"
                            Height="28"
                            MinWidth="32"
                            MinHeight="28"
                            Padding="0"
                            Margin="12,0,0,0"
                            ToolTip="Close" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="18">
                <TextBox x:Name="EditText"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         MinHeight="260" />
            </Grid>

            <UniformGrid Grid.Row="2"
                         Columns="2"
                         HorizontalAlignment="Right"
                         Width="300"
                         Margin="18,0,18,18">
                <Button x:Name="CancelButton"
                        Content="Cancel"
                        Click="CancelButton_Click"
                        Margin="0,0,8,0" />
                <Button x:Name="ApplyButton"
                        Content="Apply"
                        Click="ApplyButton_Click"
                        Margin="8,0,0,0" />
            </UniformGrid>
        </Grid>
    </Border>
</Window>
